# PostgreSQL (kontener bazy + budowa DATABASE_URL)
POSTGRES_USER=radec24
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=radec24
DATABASE_URL=postgres://radec24:CHANGE_ME@localhost:5432/radec24
NUXT_DATABASE_URL=postgres://radec24:CHANGE_ME@localhost:5432/radec24

# Sesja panelu admina (min. 32 losowe znaki) — wygeneruj: openssl rand -hex 32
NUXT_SESSION_PASSWORD=CHANGE_ME_32_CHARS_MIN

# Stały sekret do podpisywania URL-i obrazków OG (Facebook/X cache'ują og:image na długo —
# bez stałego sekretu link przestałby działać po każdym redeployu). Wygeneruj: openssl rand -hex 32
NUXT_OG_IMAGE_SECRET=CHANGE_ME_32_CHARS_MIN

# Konta panelu admina (tworzone automatycznie przy starcie, jeśli jeszcze nie istnieją)
# Po 3 nieudanych próbach logowania na dane konto wysyłany jest mail z linkiem do resetu hasła na *_RECOVERY_EMAIL
NUXT_ADMIN1_USERNAME=Technik
NUXT_ADMIN1_PASSWORD=CHANGE_ME
NUXT_ADMIN1_RECOVERY_EMAIL=patrydab4@gmail.com
NUXT_ADMIN2_USERNAME=radec24
NUXT_ADMIN2_PASSWORD=CHANGE_ME
NUXT_ADMIN2_RECOVERY_EMAIL=radec24@wp.pl

# Resend (wysyłka maila z formularza kontaktowego i resetu hasła) — https://resend.com/api-keys
NUXT_RESEND_API_KEY=re_xxxxxxxxxxxx
NUXT_CONTACT_TO_EMAIL=radec24@wp.pl
NUXT_CONTACT_FROM_EMAIL=radec24@makoto.com.pl

# Katalog na zdjęcia galerii (montowany jako wolumin w Dokploy)
NUXT_GALLERY_UPLOAD_DIR=.data/uploads

# Publiczny adres strony
NUXT_PUBLIC_SITE_URL=https://radec24.pl
