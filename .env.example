# PostgreSQL
DATABASE_URL=postgres://radec24:CHANGE_ME@localhost:5432/radec24
POSTGRES_USER=radec24
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=radec24

# Sesja panelu admina (min. 32 losowe znaki) — wygeneruj: openssl rand -hex 32
NUXT_SESSION_PASSWORD=CHANGE_ME_32_CHARS_MIN

# Konta panelu admina (tworzone automatycznie przy starcie, jeśli jeszcze nie istnieją)
ADMIN1_USERNAME=Technik
ADMIN1_PASSWORD=CHANGE_ME
ADMIN2_USERNAME=radec24
ADMIN2_PASSWORD=CHANGE_ME

# Resend (wysyłka maila z formularza kontaktowego) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_TO_EMAIL=radec24@wp.pl
CONTACT_FROM_EMAIL=radec24@makoto.com.pl

# Katalog na zdjęcia galerii (montowany jako wolumin w Dokploy)
GALLERY_UPLOAD_DIR=.data/uploads

# Publiczny adres strony
NUXT_PUBLIC_SITE_URL=https://radec24.pl
